# Google Gemini API key (default image generator: gemini-2.5-flash-image / Nano Banana)
GOOGLE_GENERATIVE_AI_API_KEY=

# Anthropic API key (used by Claude Sonnet 4.6 for VLM hotspot extraction)
ANTHROPIC_API_KEY=

# OpenAI API key (only required if IMAGE_PROVIDER=openai)
OPENAI_API_KEY=

# Image provider switch: "gemini" (default) or "openai"
IMAGE_PROVIDER=gemini

# Optional: cap total image generations per server process (per day) for cost safety
DAILY_IMAGE_GEN_LIMIT=200

# Optional: throttle window per IP (seconds)
RATE_LIMIT_WINDOW_SEC=10
